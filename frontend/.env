# ── Mock / Real 전환 ──────────────────────────────
# true  → mockData 사용 (1~2주차 개발)
# false → 아래 URL로 실서버 연결 (3주차)
VITE_USE_MOCK=true

# ── REST API ─────────────────────────────────────
# 3주차에 실서버 주소로 교체
REACT_APP_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ── WebSocket (미설정 시 REST URL에서 자동 변환) ──
# ws://실서버주소/api/v1/ws/building-A
# VITE_WS_URL=ws://localhost:8000

# ── 건물 ID (현재 고정) ───────────────────────────
VITE_BUILDING_ID=building-A
