# ── Mock / Real 전환 ──────────────────────────────
# true  → mockData 사용 (1~2주차 개발)
# false → 아래 URL로 실서버 연결 (3주차)
VITE_USE_MOCK=false

# ── REST API ─────────────────────────────────────
# 3주차에 실서버 주소로 교체
REACT_APP_API_URL=https://peakbridge-production.up.railway.app
VITE_API_URL=https://peakbridge-production.up.railway.app

# ── WebSocket (미설정 시 REST URL에서 자동 변환) ──
# ws://실서버주소/api/v1/ws/building-A
VITE_WS_URL=wss://peakbridge-production.up.railway.app

# ── 건물 ID (현재 고정) ───────────────────────────
VITE_BUILDING_ID=building-A
