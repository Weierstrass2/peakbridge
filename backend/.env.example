# PeakBridge EV 피크쉐이빙 백엔드 — 환경변수 예시
# 이 파일을 .env로 복사한 뒤 실제 값으로 수정하세요.
# cp .env.example .env

# --- 애플리케이션 ---
APP_NAME=PeakBridge EV Peak Shaving API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# --- 서버 ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- 데이터베이스 (PostgreSQL + TimescaleDB) ---
DB_URL=postgresql+asyncpg://peakbridge:peakbridge@localhost:5432/peakbridge
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- MQTT ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=peakbridge

# --- 보안 (운영 환경에서는 반드시 강력한 시크릿 사용) ---
JWT_SECRET=change-me-in-production-use-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Peak Shaving ---
PEAK_THRESHOLD_A=15.0
ESS_MIN_SOC=20.0

# --- ML ---
ML_MODEL_DIR=./data/models

# --- Power pricing (KRW/kWh) ---
KWH_PRICE=150.0
PEAK_KWH_PRICE=250.0
